{
  "name": "inatel-cypress-project",
  "version": "1.0.0",
  "description": "Projeto de automação de testes do site do Inatel com Cypress",
  "author": "Fabio Augusto Gandra Cruvine, Karolina Oliveira da Silva, Yam Sol Britto Bertamini",
  "license": "MIT",
  "scripts": {
    "cypress:abrir": "cypress open",
    "test": "cypress run",
    "test:sem-bdd": "cypress run --spec \"cypress/sem-bdd/**/*.spec.js\"",
    "test:bdd": "node scripts/run-cypress-bdd.js run",
    "abrir:sem-bdd": "cypress open",
    "abrir:bdd": "node scripts/run-cypress-bdd.js open"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.13.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "^0.28.0"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": false,
    "stepDefinitions": "cypress/bdd/step_definitions/**/*.steps.js"
  }
}
